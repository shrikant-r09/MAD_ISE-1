<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ResumeActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shrikant Rathod"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="snnenawat988@gmail.com" />

        <TextView
            android:id="@+id/phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+91 93568969**" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/holo_red_dark" />

        <TextView
            android:id="@+id/summary_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/summary_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Motivated engineering student with basic knowledge of Java and SQL, looking for an internship to gain practical experience in app development." />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/holo_red_dark" />

        <TextView
            android:id="@+id/experience_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Experience"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/experience_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Mini Project – Campus Event App\n• Designed basic UI using XML\n• Connected app with MySQL database\n• Implemented login and event registration module" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/holo_red_dark" />

        <TextView
            android:id="@+id/education_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Education"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/education_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SSC\nHSC\nB.Tech(Pursuing)" />

        <Button
            android:id="@+id/buttonLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Logout" />

    </LinearLayout>
</ScrollView>